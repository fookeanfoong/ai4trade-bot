# Release signing credentials — COPY to `android/keystore.properties` and fill in.
# This file (the real one, without .example) is GITIGNORED. Never commit it.
#
# `storeFile` is resolved relative to the android/ project root.
# Keep the keystore itself OUTSIDE the repo (e.g. ~/keys/ai4trade-release.jks)
# and point storeFile at an absolute path, or place it outside android/app.

storeFile=../ai4trade-release.jks
storePassword=CHANGE_ME
keyAlias=ai4trade
keyPassword=CHANGE_ME
