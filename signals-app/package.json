{
  "name": "ai4trade-signals",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AI4Trade Signals — educational pre-market stock analysis. Companion app to aicompareapi.com. Android / Huawei AppGallery.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "typecheck": "tsc -b --noEmit",
    "check:compliance": "node scripts/check-compliance.mjs",
    "verify": "npm run check:compliance && npm run build",
    "cap:sync": "cap sync android",
    "cap:add:android": "cap add android",
    "cap:open:android": "cap open android",
    "android:build:debug": "npm run build && cap sync android && cd android && ./gradlew assembleDebug",
    "android:build:release": "npm run build && cap sync android && cd android && ./gradlew bundleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/browser": "^6.0.4",
    "@capacitor/core": "^6.2.0",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.4",
    "i18next": "^23.16.0",
    "idb": "^8.0.0",
    "lightweight-charts": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
