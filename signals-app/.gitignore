# dependencies
node_modules/

# build output
dist/
dist-ssr/
dist-tsnode/
*.tsbuildinfo

# env / secrets
.env
.env.local
.env.*.local

# editor / OS
.DS_Store
*.log
.vscode/*
!.vscode/extensions.json
.idea/

# ============================================================================
# Android / Capacitor — the native project is generated with `cap add android`.
# Only the tracked config templates under android/ (build.gradle snippets,
# AndroidManifest additions, signing template) are committed; the rest is
# generated locally and must not be committed.
# ============================================================================
android/.gradle/
android/build/
android/app/build/
android/capacitor-cordova-android-plugins/
android/.idea/
android/local.properties

# HMS AppGallery Connect config — DO NOT COMMIT (contains project identifiers).
android/app/agconnect-services.json

# Release signing — NEVER commit the keystore or its credentials.
*.keystore
*.jks
android/keystore.properties
release-signing.properties
