# ============================================================================
# AI4Trade Signals — environment variables
# Copy to `.env` and fill in. Vite only exposes vars prefixed with VITE_.
# NEVER commit a real .env — secrets do not belong in the repo.
# ============================================================================

# Base URL of the existing aicompareapi.com REST API.
# Endpoints used: /auth/*, /signals/today, /news/latest, /guides/list,
#                 /user/acceptance, /user/entitlement
VITE_API_BASE_URL=https://aicompareapi.com/api

# --- Finnhub (News feed) ---------------------------------------------------
# Free tier: 60 calls/min. Get a key at https://finnhub.io/dashboard
# NOTE: In production, proxy Finnhub through the backend so this key is never
# shipped in the client bundle. This var exists for local/dev use only.
VITE_FINNHUB_API_KEY=

# --- Legal document versions ----------------------------------------------
# Bump these when the hosted legal docs change; the app compares them against
# the stored acceptance record and re-prompts the user to re-accept.
VITE_TERMS_VERSION=2026-01-01
VITE_PRIVACY_VERSION=2026-01-01
VITE_RISK_DISCLOSURE_VERSION=2026-01-01

# --- Support ---------------------------------------------------------------
# Address the Settings > Contact support row opens via mailto:
VITE_SUPPORT_EMAIL=support@aicompareapi.com
