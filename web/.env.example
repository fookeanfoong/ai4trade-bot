# 站点主域名(.com),用于 canonical / sitemap / hreflang
NEXT_PUBLIC_SITE_URL=https://aggreapi.com

# 资源前缀 —— 未来切国内 CDN 时设置(如 https://cdn.aggreapi.cn)
NEXT_PUBLIC_ASSET_PREFIX=

# 搜索引擎站点验证(上线时填入各平台给的值)
NEXT_PUBLIC_BAIDU_VERIFY=
NEXT_PUBLIC_360_VERIFY=
NEXT_PUBLIC_SOGOU_VERIFY=

# 自托管分析(Plausible / Umami)域名,预留百度统计位
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_UMAMI_URL=
NEXT_PUBLIC_BAIDU_TONGJI_ID=

# Google Analytics 4 —— analytics.google.com 建资源(Web)拿 Measurement ID(G-XXXXXXXXXX)
# 覆盖海外流量;国内可能被墙,由上面的自托管/百度统计覆盖。同意「分析」Cookie 后才加载。
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity —— clarity.microsoft.com 建项目拿 Project ID。免费看点击热图/会话回放。
NEXT_PUBLIC_CLARITY_ID=

# Google AdSense —— 仅用于部落格(文章内 + 侧栏两个位),同意「营销」Cookie 后才加载。
# CLIENT 为 publisher ID(ca-pub-XXXXXXXXXXXXXXXX);两个 SLOT 为在 AdSense 建的广告单元 ID。
# 三个都留空 = 部落格完全不显示广告、版式零变化。
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_INARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=

# Cloudflare Turnstile(替代 reCAPTCHA)站点密钥
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# 联盟点击后台访问令牌 —— 设置后 /admin/clicks 与 /api/stats/outbound
# 需带 ?token= 才能访问;留空则本地开发直接开放。生产务必设置。
ADMIN_TOKEN=
