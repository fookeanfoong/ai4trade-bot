// AggreAPI 数据库 schema —— 二期(托管交易)迁移目标。
// 与一期 mock(src/lib/data/*)一一对应,迁移时字段零改动。
// 一期仍用 JSON mock;此 schema 仅用于二期接入 Postgres。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ModelStatus {
  available
  degraded
  offline
}

enum ListingType {
  credit
  subscription
  topup
}

enum ListingStatus {
  external_only // 一期:仅外链
  active        // 二期:平台托管在售
  sold_out
}

enum SubmissionStatus {
  pending
  approved
  rejected
}

model Provider {
  id                  String   @id @default(cuid())
  slug                String   @unique
  name                String
  logo                String
  website             String
  affiliateUrl        String
  regions             String[]
  paymentMethods      String[]
  foundedDate         DateTime
  trustScore          Int
  uptime30d           Float
  avgLatencyMs        Int
  supportsInvoice     Boolean  @default(false)
  supportsDpa         Boolean  @default(false)
  // —— 二期字段(一期恒为默认值)——
  isMarketplaceSeller Boolean  @default(false)
  commissionRate      Float?
  // —— 展示辅助 ——
  sponsored           Boolean  @default(false)
  editorPick          Boolean  @default(false)
  newArrival          Boolean  @default(false)
  discountCode        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  models      Model[]
  reviews     Review[]
  listings    Listing[]
  favorites   Favorite[]
  priceAlerts PriceAlert[]
  clicks      OutboundClick[]

  @@index([trustScore])
  @@index([sponsored])
}

model Model {
  id                String      @id @default(cuid())
  provider          Provider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId        String
  modelName         String
  modelFamily       String
  inputPricePer1m   Float
  outputPricePer1m  Float
  officialPricePer1m Float
  discountPercent   Int
  contextLength     Int
  status            ModelStatus @default(available)
  updatedAt         DateTime    @updatedAt

  @@unique([providerId, modelName])
  @@index([modelName, outputPricePer1m])
}

// 二期托管商品(一期结构留好,status 恒为 external_only)
model Listing {
  id         String        @id @default(cuid())
  provider   Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  type       ListingType
  price      Float
  stock      Int           @default(0)
  status     ListingStatus @default(external_only)
  createdAt  DateTime      @default(now())
}

model Review {
  id               String   @id @default(cuid())
  provider         Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId       String
  rating           Int
  content          String
  verifiedPurchase Boolean  @default(false)
  region           String
  useCase          String
  author           String
  user             User?    @relation(fields: [userId], references: [id])
  userId           String?
  createdAt        DateTime @default(now())

  @@index([providerId])
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String
  createdAt   DateTime     @default(now())
  reviews     Review[]
  favorites   Favorite[]
  priceAlerts PriceAlert[]
}

model Favorite {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  createdAt  DateTime @default(now())

  @@unique([userId, providerId])
}

model PriceAlert {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  createdAt  DateTime @default(now())

  @@unique([userId, providerId])
}

// 跳转埋点(核对联盟返佣)—— 对应 /api/track/outbound
model OutboundClick {
  id         String   @id @default(cuid())
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  providerSlug String?
  sourcePage String?
  userAgent  String?
  referer    String?
  ipPrefix   String?
  ts         DateTime @default(now())

  @@index([providerId, ts])
}

// 商家自荐 —— 对应 /api/submit(二期升级为入驻申请)
model Submission {
  id          String           @id @default(cuid())
  name        String
  website     String
  contact     String
  regions     String[]
  payments    String[]
  description String?
  status      SubmissionStatus @default(pending)
  createdAt   DateTime         @default(now())
}
